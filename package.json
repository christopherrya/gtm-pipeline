{
  "name": "discloser-gtm-scripts",
  "version": "1.0.0",
  "type": "module",
  "description": "GTM automation scripts for lead enrichment and cold email campaigns",
  "scripts": {
    "start": "bash start.sh",
    "hub": "node hub/server.js",
    "orchestrator:start": "node orchestrator/server.js",
    "enrich": "node enrichment/enrich-leads.js",
    "enrich:test": "node enrichment/enrich-leads.js --test",
    "enrich:linkedin": "node enrichment/linkedin-enricher.js",
    "enrich:instagram": "node enrichment/instagram-enricher.js",
    "merge": "node enrichment/leads-merger.js",
    "hooks:extract": "node enrichment/ai-hooks-generator.js",
    "hooks:apply": "node enrichment/ai-hooks-generator.js --apply",
    "rescore": "node enrichment/rescore-leads.js",
    "listings:scrape": "node enrichment/brokerage-listings/listings-scraper.js",
    "listings:scrape:test": "node enrichment/brokerage-listings/listings-scraper.js --test",
    "listings:match": "node enrichment/brokerage-listings/listings-matcher.js",
    "listings:score": "node enrichment/brokerage-listings/listings-scorer.js",
    "setup:fields": "node scripts/setup-twenty-fields.js",
    "setup:campaigns": "node scripts/setup-instantly-campaigns.js",
    "pool:select": "node scripts/select-from-pool.js",
    "import": "node scripts/bulk-import-twenty.js",
    "batch:prepare": "node scripts/prepare-batch.js",
    "batch:nurture": "node scripts/prepare-batch.js --mode nurture",
    "batch:followup": "node scripts/prepare-batch.js --mode soft_followup",
    "batch:personalize": "node scripts/personalize-batch.js",
    "batch:push": "node scripts/push-to-instantly.js",
    "batch:sync": "node scripts/sync-status.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "apify-client": "^2.9.0",
    "csv-parse": "^5.5.0",
    "csv-stringify": "^6.4.0",
    "dotenv": "^16.3.1",
    "node-fetch": "^3.3.2",
    "puppeteer": "^22.0.0",
    "string-similarity": "^4.0.4"
  }
}
